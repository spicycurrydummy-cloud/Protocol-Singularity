# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ============================================================
# Protocol Singularity: secrets (Mercury2 API key etc.)
# ============================================================
# ローカル開発用の実設定ファイル。GitHub には Secret からビルド時注入する想定。
/[Aa]ssets/[Ss]treamingAssets/mercury2-config.json
/[Aa]ssets/[Ss]treamingAssets/mercury2-config.json.meta

# Claude Code のローカル設定 / スケジューラ (個人環境依存)
.claude/

# Unity license 取得用の中間ファイル (絶対にコミットしない)
*.alf
*.ulf
Unity_v*.x.ulf

# Unity / 開発補助ログ
debug.log
*.log

# GitHub Actions デプロイ時の作業用ファイル (コミットしない)
unity-alf/
run-logs/
*.zip
runs.json
artifacts.json
set_secret.py
dr*.json
deploy-run.json
secrets.json

# ============================================================
# ローカル開発の成果物 (絶対にコミットしない)
# ============================================================
# Unity のローカルビルド出力
/.build/
# ビルド等で生成されるログ/中間データ (リポに入れない)
/Data/

# ============================================================
# 空 or コンテンツ未committed のフォルダに付く .meta
# ----
# Unity は通常 .meta をコミットすべきだが、これらは実体が追跡されてないので
# 誤ってコミットしないよう ignore。使い始めたら `git add -f <path>` で明示追加。
# ============================================================
/Assets/Plugins.meta
/Assets/Resources.meta
/Assets/Sprites.meta
/Assets/WebGLTemplates.meta
/Assets/_ProtocolSingularity/Audios.meta
/Assets/_ProtocolSingularity/Resources/Audio.meta
/Assets/_ProtocolSingularity/Scripts/Audio.meta
# Fonts フォルダの folder .meta / ライセンス.meta (中身の .ttf / .txt は tracked)
/Assets/Fonts.meta
/Assets/Fonts/Noto_Sans_JP.meta
/Assets/Fonts/Noto_Sans_JP/OFL.txt.meta
/Assets/Fonts/Noto_Sans_JP/README.txt.meta
/Assets/Fonts/Noto_Sans_JP/static.meta
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-Regular.ttf.meta

# Noto Sans JP の未使用 variant (Regular 以外は build 対象外なのでリポに入れない)
/Assets/Fonts/Noto_Sans_JP/NotoSansJP-VariableFont_wght.ttf
/Assets/Fonts/Noto_Sans_JP/NotoSansJP-VariableFont_wght.ttf.meta
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-Black.ttf
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-Black.ttf.meta
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-Bold.ttf
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-Bold.ttf.meta
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-ExtraBold.ttf
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-ExtraBold.ttf.meta
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-ExtraLight.ttf
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-ExtraLight.ttf.meta
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-Light.ttf
/Assets/Fonts/Noto_Sans_JP/static/NotoSansJP-Light.ttf.meta
